generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                             String             @id @default(uuid())
  email                                          String             @unique
  firstName                                      String?
  lastName                                       String?
  createdAt                                      DateTime           @default(now())
  updatedAt                                      DateTime           @updatedAt
  isAdmin                                        Boolean?           @default(false)
  isOwner                                        Boolean?           @default(false)
  isTenant                                       Boolean?           @default(false)
  autoApprove                                    Boolean            @default(false)
  bufferTime                                     Int                @default(0)
  maxBookingsPerDay                              Int                @default(5)
  slotDuration                                   Int                @default(30)
  profileImage                                   String?
  nicBack                                        String?
  nicFront                                       String?
  status                                         String             @default("Active")
  verified                                       Boolean            @default(false)
  ownedSlots                                     AvailabilitySlot[] @relation("OwnerSlots")
  tenantBookings                                 Booking[]          @relation("TenantBookings")
  chatMessages                                   ChatMessage[]
  ownedThreads                                   ChatThread[]       @relation("ChatThread_ownerIdToUser")
  tenantThreads                                  ChatThread[]       @relation("ChatThread_tenantIdToUser")
  ContactMessage                                 ContactMessage[]
  LeaseAgreement_LeaseAgreement_landlordIdToUser LeaseAgreement[]   @relation("LeaseAgreement_landlordIdToUser")
  LeaseAgreement_LeaseAgreement_tenantIdToUser   LeaseAgreement[]   @relation("LeaseAgreement_tenantIdToUser")
  notifications                                  Notification[]
  properties                                     Property[]
  Review                                         Review[]
  Transaction                                    Transaction[]
}

model Property {
  id             String             @id @default(uuid())
  ownerId        String
  title          String
  description    String
  price          Float
  address        String
  city           String?
  state          String?
  zipCode        String?
  bedrooms       Int
  bathrooms      Float
  sqft           Float
  type           String
  status         String             @default("Available")
  bookingStatus  String             @default("default")
  images         String[]
  panoramaImage  String?
  amenities      String[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  waterBillImage String?
  latitude       Float?
  longitude      Float?
  isBoosted      Boolean            @default(false)
  foodName       String?
  foodPhone      String?
  jobName        String?
  jobPhone       String?
  foodFacilities String?
  partTimeJobs   String?
  slots          AvailabilitySlot[]
  bookings       Booking[]
  chatThreads    ChatThread[]
  LeaseAgreement LeaseAgreement[]
  owner          User               @relation(fields: [ownerId], references: [id])
  Review         Review[]
  Transaction    Transaction[]
}

model AvailabilitySlot {
  id           String    @id @default(uuid())
  propertyId   String
  ownerId      String
  date         DateTime
  startTime    String
  endTime      String
  slotDuration Int       @default(30)
  bufferTime   Int       @default(0)
  isBlocked    Boolean   @default(false)
  isRecurring  Boolean   @default(false)
  recurringDay Int?
  maxBookings  Int       @default(1)
  createdAt    DateTime  @default(now())
  owner        User      @relation("OwnerSlots", fields: [ownerId], references: [id])
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings     Booking[]
}

model Booking {
  id         String           @id @default(uuid())
  slotId     String
  tenantId   String
  propertyId String
  status     BookingStatus    @default(PENDING)
  note       String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  property   Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  slot       AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  tenant     User             @relation("TenantBookings", fields: [tenantId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  bookingId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  firstName String?
  lastName  String?
  mode      String
  createdAt DateTime @default(now())
  nicBack   String?
  nicFront  String?
  role      String?
}

model ChatMessage {
  id                 String     @id @default(uuid())
  threadId           String
  senderId           String
  text               String
  isRead             Boolean    @default(false)
  createdAt          DateTime   @default(now())
  translatedLanguage String?
  translatedText     String?
  sender             User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  thread             ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model ChatThread {
  id         String        @id @default(uuid())
  tenantId   String
  ownerId    String
  propertyId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  messages   ChatMessage[]
  owner      User          @relation("ChatThread_ownerIdToUser", fields: [ownerId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     User          @relation("ChatThread_tenantIdToUser", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, ownerId, propertyId])
}

model ContactMessage {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  subject   String?  @default("General Inquiry")
  message   String
  status    String   @default("Unread")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeaseAgreement {
  id                                   String    @id @default(uuid())
  tenantName                           String
  tenantEmail                          String
  landlordName                         String
  landlordEmail                        String
  monthlyRent                          Float
  securityDeposit                      Float
  termLength                           String
  startDate                            String
  endDate                              String
  status                               String    @default("Pending Signatures")
  listingName                          String
  contractText                         String
  landlordSig                          String?
  tenantSig                            String?
  createdAt                            DateTime  @default(now())
  updatedAt                            DateTime  @updatedAt
  savedInLandlordWallet                Boolean   @default(false)
  savedInTenantWallet                  Boolean   @default(false)
  visualTheme                          String?   @default("classic-legal")
  landlordId                           String?
  propertyId                           String?
  tenantId                             String?
  User_LeaseAgreement_landlordIdToUser User?     @relation("LeaseAgreement_landlordIdToUser", fields: [landlordId], references: [id])
  Property                             Property? @relation(fields: [propertyId], references: [id])
  User_LeaseAgreement_tenantIdToUser   User?     @relation("LeaseAgreement_tenantIdToUser", fields: [tenantId], references: [id])
}

model Review {
  id          String    @id @default(uuid())
  authorName  String
  authorEmail String
  rating      Int
  sentiment   String
  comment     String
  targetName  String
  likes       Int       @default(0)
  status      String    @default("Pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  authorId    String?
  propertyId  String?
  User        User?     @relation(fields: [authorId], references: [id])
  Property    Property? @relation(fields: [propertyId], references: [id])
}

model Transaction {
  id            String    @id @default(uuid())
  type          String
  amount        Float
  user          String
  email         String
  targetListing String
  status        String    @default("Pending")
  reference     String
  paymentMethod String
  ipAddress     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  propertyId    String?
  userId        String?
  Property      Property? @relation(fields: [propertyId], references: [id])
  User          User?     @relation(fields: [userId], references: [id])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
