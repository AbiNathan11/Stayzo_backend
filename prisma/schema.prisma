generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  firstName         String?
  lastName          String?
  profileImage      String?
  nicFront          String?
  nicBack           String?
  isAdmin           Boolean?           @default(false)
  isOwner           Boolean?           @default(false)
  isTenant          Boolean?           @default(false)
  autoApprove       Boolean            @default(false)
  slotDuration      Int                @default(30)
  bufferTime        Int                @default(0)
  maxBookingsPerDay Int                @default(5)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  properties        Property[]
  ownedSlots        AvailabilitySlot[] @relation("OwnerSlots")
  tenantBookings    Booking[]          @relation("TenantBookings")
  notifications     Notification[]
  tenantThreads     ChatThread[]       @relation("TenantThreads")
  ownerThreads      ChatThread[]       @relation("OwnerThreads")
  sentMessages      ChatMessage[]      @relation("UserMessages")
}

model Property {
  id             String             @id @default(uuid())
  ownerId        String
  title          String
  description    String
  price          Float
  address        String
  city           String?
  state          String?
  zipCode        String?
  bedrooms       Int
  bathrooms      Float
  sqft           Float
  type           String
  status         String             @default("Available")
  images         String[]
  panoramaImage  String?
  amenities      String[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  waterBillImage String?
  slots          AvailabilitySlot[]
  bookings       Booking[]
  ChatThread     ChatThread[]
  owner          User               @relation(fields: [ownerId], references: [id])
}

model AvailabilitySlot {
  id           String    @id @default(uuid())
  propertyId   String
  ownerId      String
  date         DateTime
  startTime    String
  endTime      String
  slotDuration Int       @default(30)
  bufferTime   Int       @default(0)
  isBlocked    Boolean   @default(false)
  isRecurring  Boolean   @default(false)
  recurringDay Int?
  maxBookings  Int       @default(1)
  createdAt    DateTime  @default(now())
  owner        User      @relation("OwnerSlots", fields: [ownerId], references: [id])
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings     Booking[]
}

model Booking {
  id         String           @id @default(uuid())
  slotId     String
  tenantId   String
  propertyId String
  status     BookingStatus    @default(PENDING)
  note       String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  property   Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  slot       AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  tenant     User             @relation("TenantBookings", fields: [tenantId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  bookingId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  firstName String?
  lastName  String?
  mode      String
  role      String?
  nicFront  String?
  nicBack   String?
  createdAt DateTime @default(now())
}

model ChatMessage {
  id         String     @id
  threadId   String
  senderId   String
  text       String
  isRead     Boolean    @default(false)
  createdAt  DateTime   @default(now())
  User       User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  ChatThread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model ChatThread {
  id                             String        @id
  tenantId                       String
  ownerId                        String
  propertyId                     String
  createdAt                      DateTime      @default(now())
  updatedAt                      DateTime
  ChatMessage                    ChatMessage[]
  User_ChatThread_ownerIdToUser  User          @relation("ChatThread_ownerIdToUser", fields: [ownerId], references: [id], onDelete: Cascade)
  Property                       Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  User_ChatThread_tenantIdToUser User          @relation("ChatThread_tenantIdToUser", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, ownerId, propertyId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
