generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                   String             @id @default(uuid())
  email                                String             @unique
  firstName                            String?
  lastName                             String?
  createdAt                            DateTime           @default(now())
  updatedAt                            DateTime           @updatedAt
  isAdmin                              Boolean?           @default(false)
  isOwner                              Boolean?           @default(false)
  isTenant                             Boolean?           @default(false)
  autoApprove                          Boolean            @default(false)
  bufferTime                           Int                @default(0)
  maxBookingsPerDay                    Int                @default(5)
  slotDuration                         Int                @default(30)
  profileImage                         String?
  ownedSlots                           AvailabilitySlot[] @relation("OwnerSlots")
  tenantBookings                       Booking[]          @relation("TenantBookings")
  chatMessages                         ChatMessage[]
  ownedThreads                         ChatThread[]       @relation("ChatThread_ownerIdToUser")
  tenantThreads                        ChatThread[]       @relation("ChatThread_tenantIdToUser")
  notifications                        Notification[]
  properties                           Property[]
}

model Property {
  id             String             @id @default(uuid())
  ownerId        String
  title          String
  description    String
  price          Float
  address        String
  city           String?
  state          String?
  zipCode        String?
  bedrooms       Int
  bathrooms      Float
  sqft           Float
  type           String
  status         String             @default("Available")
  images         String[]
  panoramaImage  String?
  amenities      String[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  waterBillImage String?
  slots          AvailabilitySlot[]
  bookings       Booking[]
  chatThreads    ChatThread[]
  owner          User               @relation(fields: [ownerId], references: [id])
}

model AvailabilitySlot {
  id           String    @id @default(uuid())
  propertyId   String
  ownerId      String
  date         DateTime
  startTime    String
  endTime      String
  slotDuration Int       @default(30)
  bufferTime   Int       @default(0)
  isBlocked    Boolean   @default(false)
  isRecurring  Boolean   @default(false)
  recurringDay Int?
  maxBookings  Int       @default(1)
  createdAt    DateTime  @default(now())
  owner        User      @relation("OwnerSlots", fields: [ownerId], references: [id])
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings     Booking[]
}

model Booking {
  id         String           @id @default(uuid())
  slotId     String
  tenantId   String
  propertyId String
  status     BookingStatus    @default(PENDING)
  note       String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  property   Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  slot       AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  tenant     User             @relation("TenantBookings", fields: [tenantId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  bookingId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  firstName String?
  lastName  String?
  mode      String
  createdAt DateTime @default(now())
}

model ChatMessage {
  id                 String     @id @default(uuid())
  threadId           String
  senderId           String
  text               String
  isRead             Boolean    @default(false)
  createdAt          DateTime   @default(now())
  translatedText     String?
  translatedLanguage String?
  sender             User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  thread             ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model ChatThread {
  id         String        @id @default(uuid())
  tenantId   String
  ownerId    String
  propertyId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  messages   ChatMessage[]
  owner      User          @relation("ChatThread_ownerIdToUser", fields: [ownerId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     User          @relation("ChatThread_tenantIdToUser", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, ownerId, propertyId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
