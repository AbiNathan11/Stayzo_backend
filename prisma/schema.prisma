// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  firstName         String?
  lastName          String?
  profileImage      String?
  nicFront          String?
  nicBack           String?
  isAdmin           Boolean?           @default(false)
  isOwner           Boolean?           @default(false)
  isTenant          Boolean?           @default(false)
  autoApprove       Boolean            @default(false)
  slotDuration      Int                @default(30)
  bufferTime        Int                @default(0)
  maxBookingsPerDay Int                @default(5)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  properties        Property[]
  ownedSlots        AvailabilitySlot[] @relation("OwnerSlots")
  tenantBookings    Booking[]          @relation("TenantBookings")
  notifications     Notification[]
  tenantThreads     ChatThread[]       @relation("TenantThreads")
  ownerThreads      ChatThread[]       @relation("OwnerThreads")
  sentMessages      ChatMessage[]      @relation("UserMessages")
}

model Property {
  id             String             @id @default(uuid())
  ownerId        String
  title          String
  description    String
  price          Float
  address        String
  city           String?
  state          String?
  zipCode        String?
  bedrooms       Int
  bathrooms      Float
  sqft           Float
  type           String
  status         String             @default("Available")
  images         String[]
  panoramaImage  String?
  waterBillImage String?
  amenities      String[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  owner          User               @relation(fields: [ownerId], references: [id])
  slots          AvailabilitySlot[]
  bookings       Booking[]
  threads        ChatThread[]
}

model AvailabilitySlot {
  id           String    @id @default(uuid())
  propertyId   String
  ownerId      String
  date         DateTime  // UTC date of this slot
  startTime    String    // "09:00"
  endTime      String    // "09:30"
  slotDuration Int       @default(30)
  bufferTime   Int       @default(0)
  isBlocked    Boolean   @default(false)
  isRecurring  Boolean   @default(false)
  recurringDay Int?      // 0=Sun … 6=Sat
  maxBookings  Int       @default(1)
  createdAt    DateTime  @default(now())
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner        User      @relation("OwnerSlots", fields: [ownerId], references: [id])
  bookings     Booking[]
}

model Booking {
  id         String            @id @default(uuid())
  slotId     String
  tenantId   String
  propertyId String
  status     BookingStatus     @default(PENDING)
  note       String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  slot       AvailabilitySlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  tenant     User              @relation("TenantBookings", fields: [tenantId], references: [id])
  property   Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // booking_request | booking_confirmed | booking_cancelled | reminder
  isRead    Boolean  @default(false)
  bookingId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  firstName String?
  lastName  String?
  mode      String
  role      String?
  nicFront  String?
  nicBack   String?
  createdAt DateTime @default(now())
}

model ChatThread {
  id         String   @id @default(uuid())
  tenantId   String
  ownerId    String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     User     @relation("TenantThreads", fields: [tenantId], references: [id], onDelete: Cascade)
  owner      User     @relation("OwnerThreads", fields: [ownerId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@unique([tenantId, ownerId, propertyId])
}

model ChatMessage {
  id                 String   @id @default(uuid())
  threadId           String
  senderId           String
  text               String
  translatedText     String?
  translatedLanguage String?
  isRead             Boolean  @default(false)
  createdAt          DateTime @default(now())

  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender     User       @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)
}
